@model Pedido
@{
    ViewData["Title"] = "Pedido";
    ViewData["SubTitle"] = $"#{Model.PedidoId}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-controller="Pedidos" asp-action="Index">Pedidos</a></li>
        <li class="breadcrumb-item active" aria-current="page">Detalle</li>
    </ol>
</nav>

<h2 class="text-center mb-3">@ViewData["Title"] <small class="text-muted fs-5">@ViewData["SubTitle"]</small></h2>

<div class="card mb-4">
    <div class="card-body small">
        <div class="row">
            <div class="col-md-4 mb-2">
                <span class="text-muted">Estado:</span>
                <span class="badge ms-1 @(Model.Estado == "pendiente" ? "text-bg-warning" : "text-bg-success")">
                    @Model.Estado
                </span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted">Fecha:</span> @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
            </div>
            @if (User.IsInRole("Administrador"))
            {
                <div class="col-md-4 mb-2">
                    <span class="text-muted">Usuario:</span> @Model.UsuarioEmail
                </div>
            }
        </div>
    </div>
</div>

@if (Model.Items != null && Model.Items.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-hover small align-middle">
            <thead class="table-light">
                <tr>
                    <th>Producto</th>
                    <th class="text-end">Precio unit.</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-end">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Titulo</td>
                        <td class="text-end">@item.Precio.ToString("C")</td>
                        <td class="text-center">@item.Cantidad</td>
                        <td class="text-end">@((item.Precio * item.Cantidad).ToString("C"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold">
                    <td colspan="3" class="text-end">Total:</td>
                    <td class="text-end">@Model.Total.ToString("C")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
