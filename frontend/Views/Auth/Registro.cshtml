@model Registro
@{
    ViewData["Title"] = "Crear cuenta";
}

<form asp-action="Registro">
    <div class="card mx-auto" style="max-width: 500px;">
        <div class="card-body">
            <h1 class="h3 text-center">Bienvenido a Mercado Libre</h1>
            <h2 class="h6 text-center text-muted">Facultad de Estadística e Informática</h2>
            <h5 class="card-title text-center mt-4">@ViewData["Title"]</h5>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating mb-3">
                <input asp-for="Nombre" class="form-control" placeholder="Nombre completo">
                <label asp-for="Nombre"></label>
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Correo electrónico">
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Contraseña">
                <label asp-for="Password"></label>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar contraseña">
                <label asp-for="ConfirmPassword"></label>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <p class="card-text small text-end">
                ¿Ya tienes cuenta? <a asp-controller="Auth" asp-action="Index" class="link-primary text-decoration-none">Inicia sesión</a>
            </p>
        </div>
        <div class="card-footer text-center">
            <button type="submit" class="btn btn-primary">Crear cuenta</button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
