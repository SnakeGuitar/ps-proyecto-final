# ============================================================
# Archivo de ejemplo para variables de entorno del proyecto.
# Copiar como ".env" en la raiz del proyecto y completar los
# valores. NUNCA commitear el archivo .env real al repositorio.
# Generar JWT_SECRET con: openssl rand -hex 64
# ============================================================

# Base de datos
DB_DATABASE=mercadolibrenode
DB_USER=mercadolibre_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# MySQL root (solo para el contenedor de la BD)
MYSQL_ROOT_PASSWORD=CAMBIAR_POR_ROOT_PASSWORD_SEGURO

# JWT - Generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_POR_SECRETO_GENERADO_CON_OPENSSL

# Entorno (development | production)
NODE_ENV=development

# Almacenamiento de archivos en BD o en disco
FILES_IN_BD=false

# Contrasenas para los seeders iniciales
ADMIN_SEED_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN_SEGURO
USER_SEED_PASSWORD=CAMBIAR_POR_PASSWORD_USUARIO_SEGURO

# Frontend ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
